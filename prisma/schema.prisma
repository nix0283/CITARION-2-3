  quietHoursStart         String?  // e.g., "22:00"
  quietHoursEnd           String?  // e.g., "08:00"
  quietHoursEnabled       Boolean  @default(false)

  // Minimum priority to notify
  minPriority       String  @default("normal") // critical, high, normal, low

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

// Notification templates for customization
model NotificationTemplate {
  id          String   @id @default(cuid())
  
  // Template identification
  type        String   @unique // ORDER_PLACED, ORDER_FILLED, etc.
  category    String   // TRADE, SYSTEM, ALERT

  // Template content with placeholders
  title       String   // e.g., "Order Placed: {{symbol}} {{direction}}"
  message     String   // e.g., "Your {{direction}} order for {{symbol}} has been placed at {{price}}"
  
  // Channel-specific templates
  telegramTemplate String?  // Markdown-formatted template for Telegram
  emailSubject     String?  // Subject line for email
  emailBody        String?  // HTML body for email

  // Template metadata
  isActive    Boolean  @default(true)
  description String?  // Human-readable description

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, isActive])
}

// ==================== LOGOS SELF-LEARNING MODELS ====================

// LogosSignalOutcome - Tracks prediction vs actual outcome for signals
model LogosSignalOutcome {
  id            String   @id @default(cuid())
  
  // Signal identification
  signalId      String   @unique // Reference to the aggregated signal
  timestamp     DateTime @default(now())
  
  // Market context
  symbol        String
  exchange      String   @default("binance")
  direction     String   // LONG, SHORT, NEUTRAL
  
  // Prediction details
  predictedConfidence Float
  predictedEntry      Float?
  predictedSL         Float?
  predictedTP         Float?
  consensus           Float
  participatingBots   String  // JSON array of bot codes
  
  // Actual outcome
  actualEntry   Float?
  actualExit    Float?
  exitTime      DateTime?
  outcome       String?  // WIN, LOSS, BREAKEVEN, PENDING
  pnlPercent    Float    @default(0)
  pnlAbsolute   Float    @default(0)
  
  // Market conditions at signal time
  marketRegime  String?  // trending, ranging, volatile
  volatility    Float?
  volume        Float?
  
  // Contribution tracking
  contributions String? // JSON: [{botCode, direction, confidence, weight, contribution}]
  
  // Learning flags
  processed     Boolean  @default(false)
  learned       Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([symbol, timestamp])
  @@index([outcome, processed])
  @@index([timestamp])
}

// LogosBotPerformance - Per-bot performance metrics for LOGOS
model LogosBotPerformance {
  id              String   @id @default(cuid())
  botCode         String   @unique
  
  // Overall metrics
  totalSignals    Int      @default(0)
  correctSignals  Int      @default(0)
  incorrectSignals Int     @default(0)
  neutralSignals  Int      @default(0)
  
  // Accuracy metrics
  overallAccuracy Float    @default(0.5)
  longAccuracy    Float    @default(0.5)
  shortAccuracy   Float    @default(0.5)
  
  // Performance by direction
  longSignals     Int      @default(0)
  shortSignals    Int      @default(0)
  correctLongs    Int      @default(0)
  correctShorts   Int      @default(0)
  
  // Confidence calibration
  avgConfidence   Float    @default(0.5)
  confidenceCalibration Float @default(1.0) // Ratio of predicted vs actual
  
  // Weight tracking
  currentWeight   Float    @default(1.0)
  previousWeight  Float    @default(1.0)
  weightHistory   String?  // JSON array of weight changes
  
  // Performance by regime
  trendingAccuracy Float   @default(0.5)
  rangingAccuracy  Float   @default(0.5)
  volatileAccuracy Float   @default(0.5)
  
  // Performance by symbol (top performers)
  topSymbols      String?  // JSON: [{symbol, accuracy, count}]
  worstSymbols    String?  // JSON: [{symbol, accuracy, count}]
  
  // Rolling metrics (last N signals)
  rollingAccuracy Float    @default(0.5)
  rollingWindow   String?  // JSON array of recent outcomes
  
  // Degradation detection
  degradationScore Float   @default(0)
  lastDegradationCheck DateTime?
  
  // Timestamps
  lastSignalTime  DateTime?
  lastOutcomeTime DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([botCode])
  @@index([overallAccuracy])
}

// LogosLearningConfig - Configuration for the learning system
model LogosLearningConfig {
  id              String   @id @default("logos_learning_config")
  
  // Weight adjustment settings
  weightAdjustmentRate Float @default(0.02) // How much to adjust weight per outcome
  minBotWeight        Float @default(0.1)
  maxBotWeight        Float @default(2.0)
  weightSmoothing     Float @default(0.3) // EMA smoothing factor
  
  // Rolling window settings
  rollingWindowSize   Int    @default(50)  // Number of signals for rolling metrics
  degradationThreshold Float @default(0.15) // Accuracy drop threshold
  degradationWindow   Int    @default(20)  // Window for degradation detection
  
  // A/B Testing settings
  abTestingEnabled    Boolean @default(true)
  abTestSampleSize    Int     @default(100)
  abTestConfidenceLevel Float @default(0.95)
  
  // Feedback loop settings
  minSamplesForAdjustment Int @default(10)
  confidenceThreshold Float @default(0.7)
  
  // Category weights (base weights for bot categories)
  operationalWeight   Float @default(1.0)
  institutionalWeight Float @default(1.2)
  frequencyWeight     Float @default(0.9)
  
  // Learning flags
  autoRecalibration   Boolean @default(true)
  recalibrationInterval Int @default(24) // Hours
  
  // Last calibration
  lastCalibration     DateTime?
  calibrationHistory  String? // JSON array of calibration events
  
  // Version
  version             Int    @default(1)
  
  updatedAt           DateTime @updatedAt
}

// LogosABTest - A/B testing for strategy variations
model LogosABTest {
  id              String   @id @default(cuid())
  
  // Test identification
  testName        String
  testType        String   // WEIGHT_VARIATION, THRESHOLD_VARIATION, ENSEMBLE_VARIATION
  status          String   @default("RUNNING") // RUNNING, COMPLETED, CANCELLED
  
  // Variants
  variantA        String   // JSON: configuration for variant A
  variantB        String   // JSON: configuration for variant B
  
  // Sample tracking
  variantASamples Int      @default(0)
  variantBSamples Int      @default(0)
  
  // Results
  variantAWins    Int      @default(0)
  variantALosses  Int      @default(0)
  variantAPnl     Float    @default(0)
  variantAAccuracy Float   @default(0)
  
  variantBWins    Int      @default(0)
  variantBLosses  Int      @default(0)
  variantBPnl     Float    @default(0)
  variantBAccuracy Float   @default(0)
  
  // Statistical significance
  pValue          Float?
  significanceReached Boolean @default(false)
  
  // Timing
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  
  // Winning variant
  winningVariant  String?  // A, B, or NULL (no significant difference)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([status, startedAt])
}

// LogosFeedbackEntry - Individual feedback entries for pattern analysis
model LogosFeedbackEntry {
  id              String   @id @default(cuid())
  outcomeId       String   // Reference to LogosSignalOutcome
  
  // Pattern identification
  patternType     String?  // WINNING, LOSING
  patternSignature String? // Hash of pattern characteristics
  
  // Pattern characteristics
  botAgreement    Float?   // How many bots agreed
  confidenceRange Float?   // Range of confidences
  regimeMatch     Boolean? // Did regime match expected
  
  // Improvement suggestions
  suggestion      String?  // JSON: improvement suggestions
  suggestionType  String?  // WEIGHT_ADJUST, THRESHOLD_CHANGE, REGIME_FILTER
  
  // Implementation status
  implemented     Boolean  @default(false)
  implementedAt   DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([patternType, createdAt])
  @@index([outcomeId])
}
