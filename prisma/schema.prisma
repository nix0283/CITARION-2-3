// ==================== EXCHANGE TRANSACTION LOG ====================
// Complete audit trail for exchange API requests/responses

model ExchangeTransactionLog {
  id              String   @id @default(cuid())
  userId          String
  accountId       String

  // Exchange details
  exchange         String   // binance, bybit, okx, bitget, bingx
  marketType       String   @default("futures")  // spot, futures, inverse

  // Request details
  endpoint         String   // e.g., /fapi/v1/order
  method          String   @default("POST")  // GET, POST, DELETE
  requestParams   String?  // JSON of request body
  clientOrderId   String?  // User-provided idempotency key

  // Response details
  responseStatus   Int?     // HTTP status code
  responseBody     String?  // JSON response
  exchangeOrderId String?  // Exchange-provided order ID

  // Timing
  requestTime    DateTime  @default(now())
  responseTime    DateTime?

  // Status
  status          String   @default("PENDING")  // PENDING, SUCCESS, FAILED, RETRY
  retryCount      Int     @default(0)
  errorCode       String?
  errorMessage     String?

  // Related trade/position
  tradeId       String?
  positionId    String?

  createdAt       DateTime @default(now())

  @@index([userId, status])
  @@index([accountId, exchange, endpoint])
  @@index([exchange, clientOrderId])
}

// ==================== IDEMPOTENCY KEY CACHE ====================
// Prevent duplicate order submissions

model IdempotencyKey {
  id          String   @id @default(cuid())
  keyHash     String   @unique  // SHA-256 hash
  key         String
  userId      String

  // Original request data
  requestJson  String  // JSON of original request

  // Result
  orderId     String?  // Resulting order ID if success
  status      String   @default("PENDING")  // PENDING, COMPLETED, EXPIRED

  // Timing
  createdAt  DateTime  @default(now())
  expiresAt  DateTime

  @@index([keyHash])
  @@index([userId, status])
  @@index([status, expiresAt])
}

// ==================== RISK SETTINGS ====================
// User-level risk management configuration

model RiskSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique

  // Daily limits
  maxDailyLoss          Float   @default(1000)  // Max daily loss in USDT
  maxDailyLossPercent   Float   @default(5)   // Max daily loss as % of balance

  // Position limits
  maxPositionSize       Float   @default(1000)  // Max single position in USDT
  maxTotalExposure      Float   @default(10000) // Max total exposure in USDT
  maxPositions         Int     @default(10)  // Max concurrent positions
  maxLeverage          Int     @default(20)  // Max leverage allowed

  // Symbol restrictions
  blacklistedSymbols    String  @default("[]")  // JSON array
  allowedSymbols       String  @default("[]")  // JSON array (empty = all allowed)

  // Risk parameters
  defaultStopLoss      Float   @default(10)  // Default SL %
  defaultTakeProfit    Float   @default(20)  // Default TP %
  minRiskRewardRatio   Float   @default(1.5) // Min R:R ratio

  // Order settings
  requireStopLoss        Boolean @default(false)  // Require SL for all orders
  requireTakeProfit     Boolean @default(false)  // Require TP for all orders
  requireConfirmation  Boolean @default(true)   // Require confirmation for live trades

  // Kill switch
  killSwitchEnabled    Boolean @default(false)
  killSwitchThreshold Float   @default(20)  // % loss to trigger

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

// ==================== DAILY RISK METRICS ====================
