// ==================== BACKUP STRATEGY ====================
// Automated backup management and recovery

model BackupRecord {
  id            String   @id @default(cuid())
  
  // Backup identification
  name          String
  description   String?
  
  // Backup details
  type          String   @default("full") // full, incremental, differential
  status        String   @default("pending") // pending, running, completed, failed, cancelled
  
  // File information
  fileName      String
  filePath      String?
  fileSize      Float    @default(0) // bytes
  checksum      String?  // SHA-256 hash for integrity
  compressed    Boolean  @default(true)
  encrypted     Boolean  @default(true)
  
  // Scope
  scope         String   @default("database") // database, config, logs, all
  tables        String   @default("[]") // JSON array of included tables
  
  // Scheduling
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  
  // Result
  errorMessage  String?
  warningCount  Int      @default(0)
  recordCount   Int      @default(0) // Number of records backed up
  
  // Retention
  expiresAt     DateTime?
  retentionDays Int      @default(30)
  
  // Trigger info
  triggeredBy   String   @default("manual") // manual, scheduled, api
  triggeredById String?  // User ID if manual
  
  // Metadata
  metadata      String   @default("{}") // JSON for additional info
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([status, createdAt])
  @@index([type, status])
  @@index([expiresAt])
}

model BackupSchedule {
  id            String   @id @default(cuid())
  
  // Schedule identification
  name          String
  description   String?
  isActive      Boolean  @default(true)
  
  // Schedule configuration
  frequency     String   @default("daily") // hourly, daily, weekly, monthly
  cronExpression String? // Custom cron expression
  
  // Time settings
  hour          Int      @default(2) // 0-23
  minute        Int      @default(0) // 0-59
  dayOfWeek     Int?     // 0-6 (Sunday = 0) for weekly
  dayOfMonth    Int?     // 1-31 for monthly
  
  // Backup configuration
  type          String   @default("full") // full, incremental
  scope         String   @default("database")
  retentionDays Int      @default(30)
  compress      Boolean  @default(true)
  encrypt       Boolean  @default(true)
  
  // Notification settings
  notifyOnSuccess Boolean @default(true)
  notifyOnFailure Boolean @default(true)
  notifyChannels  String  @default("[]") // JSON: ["telegram", "email"]
  
  // Last run
  lastRunAt     DateTime?
  lastRunStatus String?
  nextRunAt     DateTime?
  
  // Statistics
  totalRuns     Int      @default(0)
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([isActive, nextRunAt])
}

model BackupConfig {
  id            String   @id @default(cuid())
  
  // General settings
  enabled       Boolean  @default(true)
  
  // Storage settings
  storageType   String   @default("local") // local, s3, gcs, azure
  storagePath   String   @default("./backups")
  
  // Cloud storage config (encrypted)
  cloudConfig   String?  // JSON with encrypted credentials
  
  // Retention policy
  defaultRetentionDays Int @default(30)
  maxBackups    Int      @default(100)
  minFreeSpace  Float    @default(10) // GB
  
  // Encryption
  encryptionEnabled Boolean @default(true)
  encryptionKey     String? // Encrypted master key
  
  // Compression
  compressionEnabled Boolean @default(true)
  compressionLevel   Int    @default(6) // 1-9
  
  // Performance
  maxConcurrentBackups Int @default(1)
  backupTimeout        Int @default(3600) // seconds
  
  // Notifications
  notificationEmail   String?
  notificationTelegram String?
  
  // Statistics
  totalBackups      Int   @default(0)
  totalSizeBytes    Float @default(0)
  lastBackupAt      DateTime?
  lastSuccessfulAt  DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RestoreRecord {
  id            String   @id @default(cuid())
  
  // Restore identification
  backupId      String?
  backupName    String
  
  // Status
  status        String   @default("pending") // pending, running, completed, failed, cancelled
  
  // Restore options
  restoreMode   String   @default("replace") // replace, merge, new_database
  targetScope   String   @default("database")
  targetTables  String   @default("[]") // JSON array
  
  // Progress
  startedAt     DateTime?
  completedAt   DateTime?
  progress      Float    @default(0) // 0-100
  
  // Result
  recordsRestored Int    @default(0)
  tablesRestored  Int    @default(0)
  errorMessage    String?
  
  // Trigger
  triggeredBy   String   @default("manual")
  triggeredById String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([status, createdAt])
}

